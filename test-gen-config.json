{
    "enabled": "true",
    "increase-coverage": {
      "project-name": "eval-node-express-boilerplate",
      "target-branches": [
        "master"
      ],
      "test-env-docker-stage": "node-app",
      "build-test-env-docker-stage-script-path": "tool/build-test-env-docker-stage.sh",
      "test-files-folders": [
        "tests",
        "coverage"
      ],
      "source-test-file-paths": [
        {
          "source-file-path": "src/middlewares/error.js",
          "test-file-path": "tests/unit/middlewares/error.test.js"
        }
      ],
      "test-command": "npm run coverage",
      "coverage-type": "lcov",
      "code-coverage-report-path": "coverage/lcov.info",
      "desired-coverage": 90,
      "max-iterations": 2,
      "max-number-of-test-cases": 6
    }
  }